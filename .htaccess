# Commerza Apache rules

Options -Indexes
ErrorDocument 404 /error

<IfModule mod_expires.c>
ExpiresActive On
ExpiresDefault "access plus 10 minutes"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType text/javascript "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/jpeg "access plus 1 month"
ExpiresByType image/webp "access plus 1 month"
ExpiresByType image/gif "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType image/x-icon "access plus 1 month"
ExpiresByType font/woff "access plus 1 month"
ExpiresByType font/woff2 "access plus 1 month"
ExpiresByType application/font-woff "access plus 1 month"
ExpiresByType video/mp4 "access plus 1 month"
ExpiresByType video/webm "access plus 1 month"
</IfModule>

FileETag MTime Size

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml font/ttf font/otf
</IfModule>

<IfModule mod_brotli.c>
AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_headers.c>
<FilesMatch "\.(?:css|js|mjs|png|jpe?g|gif|webp|svg|ico|avif|woff2?|ttf|eot|mp4|webm)$">
Header set Cache-Control "public, max-age=2592000, immutable, stale-while-revalidate=604800, stale-if-error=2592000"
</FilesMatch>
Header append Vary Accept-Encoding
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

# Deny uncommon HTTP methods that should never be used by the storefront.
RewriteCond %{REQUEST_METHOD} ^(?:TRACE|TRACK)$ [NC]
RewriteRule ^ - [F,L]

# Protect environment, dumps, docs, and VCS metadata from direct access.
RewriteRule (^|/)(?:\.env(?:\..*)?|\.ht(?:access|passwd)|web\.config|Thumbs\.db|Desktop\.ini|\.DS_Store|composer\.(?:json|lock)|package(?:-lock)?\.json|phpunit\.xml|README\.md|SECURITY\.md|instructions\.md|llms\.txt|backend/database/.*\.sql|.*\.(?:sql|bak|log|ini|ps1|sh))$ - [F,L,NC]
RewriteRule (^|/)\.(?:git|svn|hg)(?:/|$) - [F,L,NC]
RewriteRule ^backend/database(?:/|$) - [F,L,NC]
RewriteRule ^backend/(?:data|mailer|nav_state|notifications|rate_limit|cart_helpers|coupon_helpers|payment_helpers|security_helpers|security_events|products_schema_helpers|expiry_cleanup|send_engagement_reminders|weekly_analytics_report|monthly_profit_report)\.php$ - [F,L,NC]
RewriteRule ^admin/backend/auth\.php$ - [F,L,NC]

# Block direct browser navigation to backend/admin backend PHP scripts.
# Keep non-navigation API calls (fetch/XHR or JSON clients) operational.
RewriteCond %{REQUEST_URI} (?:^|/)(?:admin/)?backend/[^/]+\.php$ [NC]
RewriteCond %{REQUEST_METHOD} ^(?:GET|HEAD)$ [NC]
RewriteCond %{HTTP_SEC_FETCH_DEST} =document [OR]
RewriteCond %{HTTP_SEC_FETCH_MODE} =navigate [OR]
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteRule ^ - [F,L]

# Legacy .php to clean-path redirects are handled in PHP entry pages to avoid
# malformed Location headers on some Windows Apache setups.

# Clean storefront routes.
RewriteRule ^$ index.php [QSA,L,NC]
RewriteRule ^home/?$ index.php [QSA,L,NC]
RewriteRule ^index/?$ index.php [QSA,L,NC]
RewriteRule ^error/?$ 404.php [QSA,L,NC]

RewriteRule ^product/([a-z0-9-]+)/?$ products.php?slug=$1 [QSA,L,NC]
RewriteRule ^product/?$ products.php [QSA,L,NC]
RewriteRule ^products/([a-z0-9-]+)/?$ products.php?slug=$1 [QSA,L,NC]
RewriteRule ^prodcuts/([a-z0-9-]+)/?$ products.php?slug=$1 [QSA,L,NC]
RewriteRule ^products/?$ products.php [QSA,L,NC]

RewriteRule ^account/([a-z0-9_]+)/?$ account.php?u=$1 [QSA,L,NC]
RewriteRule ^account/?$ account.php [QSA,L,NC]

RewriteRule ^cart/?$ cart.php [QSA,L,NC]
RewriteRule ^wishlist/?$ wishlist.php [QSA,L,NC]
RewriteRule ^compare/?$ compare.php [QSA,L,NC]
RewriteRule ^login/?$ login.php [QSA,L,NC]
RewriteRule ^signup/?$ signup.php [QSA,L,NC]
RewriteRule ^forgot-password/?$ forgot-password.php [QSA,L,NC]
RewriteRule ^reset-password/?$ reset-password.php [QSA,L,NC]
RewriteRule ^order-tracking/?$ order-tracking.php [QSA,L,NC]
RewriteRule ^invoice/?$ invoice.php [QSA,L,NC]
RewriteRule ^oauth/?$ oauth.php [QSA,L,NC]

RewriteRule ^about/?$ about.php [QSA,L,NC]
RewriteRule ^contact/?$ contact.php [QSA,L,NC]
RewriteRule ^faq/?$ faq.php [QSA,L,NC]
RewriteRule ^shipping/?$ shipping.php [QSA,L,NC]
RewriteRule ^returns/?$ returns.php [QSA,L,NC]
RewriteRule ^privacy-policy/?$ privacy-policy.php [QSA,L,NC]
RewriteRule ^terms-of-service/?$ terms-of-service.php [QSA,L,NC]
RewriteRule ^warranty/?$ warranty.php [QSA,L,NC]
RewriteRule ^shop-category-a/?$ shop-category-a.php [QSA,L,NC]
RewriteRule ^shop-category-b/?$ shop-category-b.php [QSA,L,NC]

# Clean admin frontend routes.
RewriteRule ^admin/?$ admin/frontend/admin-login.php [QSA,L,NC]
RewriteRule ^admin-login/?$ admin/frontend/admin-login.php [QSA,L,NC]
RewriteRule ^admin-panel/?$ admin/frontend/admin-panel.php [QSA,L,NC]
RewriteRule ^admin-forgot-password/?$ admin/frontend/admin-forgot-password.php [QSA,L,NC]
RewriteRule ^admin-forgot-email/?$ admin/frontend/admin-forgot-email.php [QSA,L,NC]
RewriteRule ^admin-verify-2fa/?$ admin/frontend/admin-verify-2fa.php [QSA,L,NC]
RewriteRule ^admin-login\.php$ admin/frontend/admin-login.php [QSA,L,NC]
RewriteRule ^admin-panel\.php$ admin/frontend/admin-panel.php [QSA,L,NC]
RewriteRule ^admin-forgot-password\.php$ admin/frontend/admin-forgot-password.php [QSA,L,NC]
RewriteRule ^admin-forgot-email\.php$ admin/frontend/admin-forgot-email.php [QSA,L,NC]
RewriteRule ^admin-verify-2fa\.php$ admin/frontend/admin-verify-2fa.php [QSA,L,NC]

# Keep real files and folders untouched (including backend/admin APIs).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route unknown browser document requests to the custom 404 page.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{HTTP_SEC_FETCH_DEST} =document [OR]
RewriteCond %{HTTP_SEC_FETCH_MODE} =navigate [OR]
RewriteCond %{HTTP_ACCEPT} text/html [NC]
RewriteRule ^ 404.php [QSA,L]
</IfModule>
