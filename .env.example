COMMERZA_APP_URL=http://localhost/commerza
# Production example: COMMERZA_APP_URL=https://commerza.ahmershah.dev

COMMERZA_DB_HOST=localhost
COMMERZA_DB_USER=root
COMMERZA_DB_PASS=
COMMERZA_DB_NAME=commerza
COMMERZA_DB_PORT=
COMMERZA_DB_SOCKET=

COMMERZA_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
COMMERZA_GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
COMMERZA_GOOGLE_REDIRECT_URI=http://localhost/commerza/oauth.php?provider=google
# Production example: COMMERZA_GOOGLE_REDIRECT_URI=https://commerza.ahmershah.dev/oauth.php?provider=google

COMMERZA_FACEBOOK_CLIENT_ID=YOUR_FACEBOOK_CLIENT_ID
COMMERZA_FACEBOOK_CLIENT_SECRET=YOUR_FACEBOOK_CLIENT_SECRET
COMMERZA_FACEBOOK_REDIRECT_URI=http://localhost/commerza/oauth.php?provider=facebook
# Production example: COMMERZA_FACEBOOK_REDIRECT_URI=https://commerza.ahmershah.dev/oauth.php?provider=facebook

COMMERZA_CHECKOUT_PAYMENT_MODE=cod_stripe
COMMERZA_COD_OTP_THRESHOLD=15000
COMMERZA_COD_HIGH_VALUE_HARD_LIMIT=0
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

COMMERZA_CLOUDINARY_ENABLED=0
COMMERZA_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
COMMERZA_CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
COMMERZA_CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
COMMERZA_CLOUDINARY_FOLDER=commerza
COMMERZA_CLOUDINARY_UPLOAD_PRESET_IMAGE=commerza_image_optimized
COMMERZA_CLOUDINARY_UPLOAD_PRESET_VIDEO=commerza_video_optimized
COMMERZA_CLOUDINARY_IMAGE_TRANSFORMATION=f_auto,q_auto,c_limit,w_2200,h_2200
COMMERZA_CLOUDINARY_VIDEO_TRANSFORMATION=f_auto,q_auto:good,vc_auto
COMMERZA_CLOUDINARY_TIMEOUT=45

COMMERZA_CART_WISHLIST_EXPIRY_HOURS=72

COMMERZA_SMTP_HOST=smtp.gmail.com
COMMERZA_SMTP_PORT=587
COMMERZA_SMTP_ENCRYPTION=tls
COMMERZA_SMTP_USERNAME=YOUR_SMTP_USERNAME
COMMERZA_SMTP_PASSWORD=YOUR_SMTP_PASSWORD
COMMERZA_SMTP_FROM_EMAIL=YOUR_SENDER_EMAIL
COMMERZA_SMTP_FROM_NAME=Commerza
COMMERZA_SMTP_TIMEOUT=20
COMMERZA_SUPPORT_EMAIL=support@example.com

COMMERZA_SMTP_PRIMARY_HOST=
COMMERZA_SMTP_PRIMARY_PORT=587
COMMERZA_SMTP_PRIMARY_ENCRYPTION=tls
COMMERZA_SMTP_PRIMARY_AUTH=login
COMMERZA_SMTP_PRIMARY_USERNAME=
COMMERZA_SMTP_PRIMARY_PASSWORD=
COMMERZA_SMTP_PRIMARY_FROM_EMAIL=
COMMERZA_SMTP_PRIMARY_FROM_NAME=Commerza
COMMERZA_SMTP_PRIMARY_TIMEOUT=20

COMMERZA_SMTP_SECONDARY_HOST=smtp.gmail.com
COMMERZA_SMTP_SECONDARY_PORT=587
COMMERZA_SMTP_SECONDARY_ENCRYPTION=tls
COMMERZA_SMTP_SECONDARY_AUTH=login
COMMERZA_SMTP_SECONDARY_USERNAME=YOUR_SMTP_USERNAME
COMMERZA_SMTP_SECONDARY_PASSWORD=YOUR_SMTP_PASSWORD
COMMERZA_SMTP_SECONDARY_FROM_EMAIL=YOUR_SENDER_EMAIL
COMMERZA_SMTP_SECONDARY_FROM_NAME=Commerza
COMMERZA_SMTP_SECONDARY_TIMEOUT=20

COMMERZA_CAPTCHA_REQUIRED=1
COMMERZA_CAPTCHA_ENABLED=1
COMMERZA_CAPTCHA_BYPASS_LOCAL=0
COMMERZA_CAPTCHA_REMOTE_LOCAL=0
COMMERZA_CAPTCHA_PROVIDER=recaptcha
# Register both localhost and commerza.ahmershah.dev in your reCAPTCHA key settings.
COMMERZA_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
COMMERZA_RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
COMMERZA_RECAPTCHA_V3_SITE_KEY=YOUR_RECAPTCHA_V3_SITE_KEY
COMMERZA_RECAPTCHA_V3_SECRET_KEY=YOUR_RECAPTCHA_V3_SECRET_KEY
COMMERZA_RECAPTCHA_V3_MIN_SCORE=0.65

COMMERZA_ADMIN_RESET_KEY=SET_A_LONG_RANDOM_ADMIN_RESET_KEY
COMMERZA_ADMIN_BOOTSTRAP_EMAIL=commerza.ahmer@gmail.com
COMMERZA_ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
COMMERZA_ADMIN_TEST_EMAIL=
COMMERZA_ADMIN_TEST_PASSWORD=
COMMERZA_ADMIN_TEST_2FA_CODE=
COMMERZA_ADMIN_TEST_SESSION_ID=
COMMERZA_OAUTH_STRICT_SSL=0
